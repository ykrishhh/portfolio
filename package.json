{
  "name": "portfolio-site-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "postbuild": "node scripts/prerender.mjs",
    "start": "node --import tsx server/index.ts",
    "start:dev": "vite preview",
    "seed": "tsx server/seed.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "deploy": "npx gh-pages --dotfiles -d dist"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "clsx": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "marked": "^18.0.6",
    "motion": "^12.42.2",
    "nodemailer": "^9.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.0.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21"
  },
  "allowScripts": {
    "esbuild": true
  }
}
