# Admin credentials (change immediately after first deploy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# JWT secret for admin auth tokens — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret

# CORS: frontend production URL (comma-separated for multiple origins)
CORS_ORIGIN=https://ykrishhh.github.io

# ── Email notifications (optional) ──
# When someone submits a contact form, a notification is sent here.
# SMTP_HOST= smtp.gmail.com
# SMTP_PORT= 587
# SMTP_SECURE= false
# SMTP_USER= your-email@gmail.com
# SMTP_PASS= your-app-password
# NOTIFICATION_EMAIL= where-notifications-go@gmail.com
# SMTP_FROM= noreply@yourdomain.com

# ── Railway deployment ──
# Set VITE_API_URL as a Railay Environment Variable (not in .env) so the
# frontend build picks up the correct backend URL at deploy time.
# Example: VITE_API_URL=https://portfolio-api.up.railway.app
